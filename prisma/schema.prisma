generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ScheduledAlarm {
  id            String   @id @default(cuid())
  interactionId String   @unique
  createdBy     String
  guildId       String
  channelId     String
  timezone      String
  time          String
  message       String
  dayNumber     String   // "*" for one-time, "0"-"6" for recurring (Monday=0)
  cronExpression String
  executionTime DateTime? // Only for one-time alarms
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([guildId])
  @@index([createdBy])
  @@index([isActive])
}
